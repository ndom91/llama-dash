# Active inference backend. Only llama-swap is currently implemented.
INFERENCE_BACKEND=llama-swap

# Inference backend base URL (no trailing slash)
INFERENCE_BASE_URL=

# Skip TLS certificate verification for inference backend (true/false)
INFERENCE_INSECURE=false

# Path to llama-swap's config.yaml (absolute path on disk).
# Required for the config editor. In Docker Compose, this is
# bind-mounted and defaults to /config/config.yaml.
INFERENCE_CONFIG_FILE=

# SQLite database path, relative to project root
DATABASE_PATH=data/dash.db

# better-auth URL and secret for authentication
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=

# Additional trusted origin for internal/server-to-server auth calls
# (e.g. http://localhost:3000 when BETTER_AUTH_URL is the public host
# behind a reverse proxy). Added to better-auth trustedOrigins so the
# CSRF/origin check accepts internal requests.
INTERNAL_ORIGIN=

# Optional 32+ byte secret used to encrypt upstream provider credentials at rest.
# Required before creating or using stored upstream credentials.
CREDENTIAL_ENCRYPTION_KEY=

# Upstream proxy fetch timeouts in milliseconds. 0 disables the timeout.
# Headers timeout must stay generous: long non-streaming jobs (e.g. image
# generation) send no response headers until the full result is rendered, so a
# low value reports them as upstream_unreachable. Defaults: 600000 (10 min)
# headers, 0 (no cap) body.
UPSTREAM_HEADERS_TIMEOUT_MS=600000
UPSTREAM_BODY_TIMEOUT_MS=0

# Optional. If set, /metrics requires Authorization: Bearer <token>.
# If unset, the /metrics endpoint will be unauthenticated.
# METRICS_TOKEN=
